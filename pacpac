#!/usr/bin/env bash
set -euo pipefail

[ "$UID" = 0 ] && {
    echo Do not run me as root
    exit 1
}

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
if [[ "$SCRIPT_DIR" =~ ^/usr/ ]]; then
    cd /usr/share/pacpac
else
    cd "$SCRIPT_DIR"
fi

PKGFILE="${XDG_CONFIG_HOME:-$HOME/.config}/pacpac/packages.yml"
[ -f "$PKGFILE" ] || PKGFILE="group_vars/all.yml"
HOSTNAME=$(hostname)
PACMAN="pacman"
ANSIBLE_PLAYBOOK="pacpac.yml"

RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
NOCOLOR='\033[0m'

get_saved_packages()
{
    yq -r ".pacpac_packages[] | select((.machines == null or (.machines | index(\"$HOSTNAME\"))) and (.aur != true)) | .name" "$PKGFILE"
}

get_installed_packages()
{
    $PACMAN -Qqen
}

show_diff()
{
    saved=$(get_saved_packages)
    installed=$(get_installed_packages)
    extras=$(comm -23 <(sort <<<"$installed") <(sort <<<"$saved"))
    missing=$(comm -13 <(sort <<<"$installed") <(sort <<<"$saved"))
    echo -e "${YELLOW}Extras (installed not in list):${NOCOLOR}"
    echo -e "$extras" | column -x
    echo -e "${YELLOW}Missing (in list not installed):${NOCOLOR}"
    echo -e "$missing" | column -x
}

add_extras_to_yml()
{
    extras="$1"
    if [ -n "$extras" ]; then
        echo "# BEGIN AUTOGENERATED PACKAGES BY PACPAC $(date +%c)" >>"$PKGFILE"
        # shellcheck disable=2086
        aur="$($PACMAN -Qqm $extras)"
        # shellcheck disable=2086
        native="$($PACMAN -Qqn $extras)"
        if [ -n "$native" ]; then
            for p in $native; do
                echo "  - name: $p" >>"$PKGFILE"
            done
        fi
        if [ -n "$aur" ]; then
            for p in $aur; do
                echo "  - name: $p" >>"$PKGFILE"
                echo "    aur: true" >>"$PKGFILE"
            done
        fi
        echo "# END AUTOGENERATED PACKAGES BY PACPAC" >>"$PKGFILE"
        echo -e "${GREEN}Added extras to $PKGFILE. Review manually.${NOCOLOR}"
    fi
}

remove_orphans()
{
    orphans=$($PACMAN -Qqdt)
    if [ -n "$orphans" ]; then
        echo -e "${RED}Orphans:${NOCOLOR} $orphans"
        echo "$orphans" | sudo $PACMAN -Rs -
    fi
}

run_playbook()
{
    sudo ansible-playbook -e "@$PKGFILE" "$ANSIBLE_PLAYBOOK" "$@"
}

ask()
{
    local prompt="$1"
    local response
    while true; do
        echo -e "${GREEN}$prompt ${YELLOW}[Y/n]${NOCOLOR}: "
        read -r response
        case "$response" in
            "" | [Yy]*) return 0 ;;
            [Nn]*) return 1 ;;
            *) echo "Please answer y or n (or press Enter for yes)." ;;
        esac
    done
}

interactive_menu()
{
    echo -e "${GREEN}Let me help you with pacman package management${NOCOLOR}"
    show_diff
    ask "Install missing packages?" && run_playbook --skip-tags asdeps
    show_diff
    ask "Add extra packages to package list?" && add_extras_to_yml "$(comm -23 <(sort <<<"$(get_installed_packages)") <(sort <<<"$(get_saved_packages)"))"
    show_diff
    ask "Prepare extra packages for removal?" && run_playbook --skip-tags install
    show_diff
    ask "Remove orphans?" && remove_orphans
}

interactive_menu
